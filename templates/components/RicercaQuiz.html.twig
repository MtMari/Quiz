<div{{ attributes }}>

    <div class="input-group w-75 ms-1">
        <span class="input-group-text"><i class="bi bi-search"></i></span>
        <input
            type="search"
            name="query"
            data-model=query
            placeholder="Cerca un argomento..."
            class="form-control"
        >
    </div>
    <div class="row d-flex  d-flex">
        {% for argomento in this.argomenti %}
            <div class="col-sm-4">
                <div class="card  m-3">
                    <div class="card-body d-flex flex-column align-items-center">
                        <h5 class="card-title">{{ argomento.nomeArgomento }}</h5>
                        <p class="card-text">{{ argomento.descrizione }}</p>
                        <a href="{{ path('app_quiz_argomento', { nomeArgomento: argomento.nomeArgomento|replace({' ': '-'}) }) }}" class="btn btn-success bg-gradient"><i class="bi bi-chevron-right mx-2"></i></a>
                    </div>
                </div>
            </div>
        {% else %}
            <p class="d-flex flex-column align-items-center mt-4 fs-4">Nessun quiz per la seguente ricerca: '{{query}}'</p>
        {% endfor %}
    </div>
</div>
