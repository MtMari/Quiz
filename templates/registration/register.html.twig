{% extends 'base.html.twig' %}

{% block title %}Registrati{% endblock %}

{% block body %}

    {% import "macros/_navbar.html.twig" as navbar %}
    {{ navbar.navbar(activeRegister: 'text-decoration-underline fw-bold')}}

    <div class="d-flex justify-content-center">
        {{ form_errors(registrationForm) }}
        <div class="d-flex align-items-center flex-column  card p-5 py-4">
            <h1>Registrazione</h1>

            {{ form_start(registrationForm) }}
                <div class="d-flex p-2 align-items-center flex-column">

                    {{ form_row(registrationForm.username) }}
                    {{ form_row(registrationForm.email) }}
                    {{ form_row(registrationForm.plainPassword) }}
                    {% if is_granted('ROLE_ADMIN') %}
                        {{ form_row(registrationForm.roles) }}
                    {% else %}
                        {{ form_row(registrationForm.roles, {'attr': {'class': 'd-none'}}) }}
                    {% endif %}                    
                    {{ form_row(registrationForm.agreeTerms) }}

                    <button type="submit" class="btn btn-success bg-gradient">Conferma!</button>
                </div>
            {{ form_end(registrationForm) }}
        </div>
    </div>
{% endblock %}
