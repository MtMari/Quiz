{% extends 'base.html.twig' %}

{% block title %}Home{% endblock %}

{% block body %}

    {% import "macros/_navbar.html.twig" as navbar %}
    {{ navbar.navbar(activeHome: 'text-decoration-underline fw-bold')}}
    
    <div class="m-2">
        <div class="example-wrapper">
            <h1>{{ titolo }}! ✅</h1>
            <p>{{ testo }}</p>
        </div>
        <section>
            <div class="card p-3">
                <h5>In evidenza</h5>
                <div class="row d-flex justify-content-around">
                    {% for argomento in (argomenti|shuffle)|slice(0, 3) %}
                        <div class="col-sm-4">
                            <div class="card">
                                <div class="card-body d-flex flex-column align-items-center">
                                    <h5 class="card-title">{{ argomento.nomeArgomento }}</h5>
                                    <p class="card-text">{{ argomento.descrizione }}</p>
                                    <a href="{{ path('app_quiz_argomento', { nomeArgomento: argomento.nomeArgomento|replace({' ': '-'}) }) }}" class="btn btn-success bg-gradient">Fai il Quiz!</a>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
                <div class="d-flex justify-content-center mt-5">
                    <a href="{{ path('app_quiz') }}" class="btn btn-outline-success w-25 bg-gradient">Altro...</a>
                </div>
            </div>
        </section>
    </div>

{% endblock %}
