{% extends 'base.html.twig' %}

{% block title %}Domanda - Info{% endblock %}

{% block body %}
    {% import "macros/_navbar.html.twig" as navbar %}
    {{ navbar.navbar()}}

    {# <h1>Dati Domanda</h1> #}

    <div class="mb-4 m-2 d-flex align-items-center gap-4">
        <a class="btn btn-outline-dark" href="{{ path('app_quiz_index') }}">&lt; Indietro</a>
        <a class="btn btn-outline-info" href="{{ path('app_domanda_edit', { 'id': domanda.id }) }}">Modifica</a>
    </div>
    <table class="table table-bordered">
        <thead>
            <th class="text-center">ID</th>
            <th>Argomento</th>
            <th>ID</th>
            <th>Domanda</th>
            <th class="text-center">ID</th>
            <th>Risposte Corrette</th>
        </thead>
        <tbody>
            <tr>
                <td  class="text-center align-middle" rowspan="{{ rispostasCorrette|length }}">{{ domanda.argomento.id }}</td>
                <td  class="align-middle" rowspan="{{ rispostasCorrette|length }}">{{ domanda.argomento.nomeArgomento }}</td>
                <td  class="text-center align-middle" rowspan="{{ rispostasCorrette|length }}">{{ domanda.id }}</td>
                <td  class="align-middle" rowspan="{{ rispostasCorrette|length }}">{{ domanda.testoDomanda }}</td>
                {% for risposta in rispostasCorrette|slice(0,1) %}
                    <td class="text-center">{{risposta.id}}</td>
                    <td>{{risposta.testoRisposta}}</td>
                {% endfor %}
                {% if rispostasCorrette|length > 1 %}
                    {% for risposta in rispostasCorrette|slice(1) %}
                        <tr class="align-middle">
                            <td class="text-center">{{risposta.id}}</td>
                            <td>{{ risposta.testoRisposta }}</td>
                        </tr>
                    {% endfor %}
                {% endif %}
            </tr>
            <tr class="align-middle">
                <th class="text-center" colspan="3">ID</th>
                <th colspan="3">Risposte Sbagliate</th>
            </tr>
            {% for risposta in rispostasSbagliate %}
                <tr class="align-middle">
                    <td class="text-center" colspan="3">{{risposta.id}}</td>
                    <td colspan="3">{{ risposta.testoRisposta }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    {{ include('domanda/_delete_form.html.twig') }}
{% endblock %}
