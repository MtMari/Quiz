{% extends 'base.html.twig' %}

{% block title %}Quiz - Indice{% endblock %}

{% block body %}
    {% import "macros/_navbar.html.twig" as navbar %}
    {{ navbar.navbar(activeIndiceQuiz: 'text-decoration-underline fw-bold')}}

    {# <twig:TabellaConRicerca dati="{{ dati }}"/> #}
    <table class="table table-bordered table-responsive align-middle mt-3">
        <thead class="text-center">
            <tr class="fs-5">
                <th>ID</th>
                <th>ARGOMENTO</th>
                <th>ACTIONS</th>
                <th>ID</th>
                <th>DOMANDE</th>
                <th>INFO</th>
            </tr>
        </thead>    
        <tbody>
            {% for item in dati %}
                {% if item.domandas|length is same as 0 %}
                    <tr>
                        <td class="text-center">{{item.id}}</td>
                        <td class="text-center">{{item.nomeArgomento}}</td>
                        <td class="text-center">
                            <a href=" {{path('app_argomento_show', {'id': item.id}) }}"><i class="bi bi-info-circle-fill"></i></a>
                            <a href="{{ path('app_domanda_new', {'nomeArgomento': item.nomeArgomento})}}" class="btn btn-outline-success btn-sm fs-6"><i class="bi bi-plus-circle-fill me-1"></i>Domande</a>
                        </td>
                        <td colspan="3" class="text-center no-data bg-light fst-italic">Nessuna domanda per questo argomento.</td>
                    </tr>
                {% else %}
                    <tr>
                        <td rowspan="{{item.domandas|length}}" class="text-center">{{item.id}}</td>
                        <td rowspan="{{item.domandas|length}}" class=" text-center">{{item.nomeArgomento}}</td>
                        <td rowspan="{{item.domandas|length}}" class=" text-center">
                            <a href=" {{path('app_argomento_show', {'id': item.id}) }}"><i class="bi bi-info-circle-fill"></i></a>
                            <a href="{{ path('app_domanda_new', {'nomeArgomento': item.nomeArgomento})}}" class="btn btn-outline-success btn-sm fs-6"><i class="bi bi-plus-circle-fill me-1"></i>Domande</a>
                        </td>
                        {% for domanda in item.domandas|slice(0,1) %}
                            <td class="text-center">{{domanda.id}}</td>
                            <td class="text-start">
                                {{domanda.testoDomanda}}
                            </td>
                            <td class=" text-center"><a href=" {{path('app_domanda_show', {'id': domanda.id}) }}"><i class="bi bi-info-circle-fill"></i></a></i></td>
                        {% endfor %}
                    </tr>
                    {% if item.domandas|length > 1 %}
                        {% for domanda in item.domandas|slice(1) %}
                            <tr>
                                <td class="text-center">{{domanda.id}}</td>
                                <td>
                                    {{domanda.testoDomanda}}
                                </td>
                                <td class=" text-center"><a href=" {{path('app_domanda_show', {'id': domanda.id}) }}"><i class="bi bi-info-circle-fill"></i></a></td>
                            </tr>
                        {% endfor %}
                    {% endif %}
                {% endif %}
            {% endfor %}
        </tbody>
    </table>
{% endblock %}
