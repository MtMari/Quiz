{% extends 'base.html.twig' %}

{% block title %}Quiz - {{nomeArgomento|replace({'-':' '})}} {% endblock %}

{% block body %}
    {% import "macros/_navbar.html.twig" as navbar %}
    {{ navbar.navbar()}}

    <h1 class="m-2">{{ nomeArgomento|replace({'-':' '}) }}</h1>

    <hr>

    <form action="{{ path('app_quiz_risultato', { nomeArgomento: nomeArgomento|replace({'-':' '}) }) }}" method="POST">
        {% for item in dati %}
            <ul>
                {% for domanda in item.domandas|shuffle %}
                <div>
                    <li>{{domanda.testoDomanda}}</li>
                    {% for risposta in domanda.rispostas|shuffle %}
                        <input type="checkbox" id="{{risposta.id}}" name="{{risposta.id}}" value="{{risposta.id}}">
                        <label for="{{risposta.id}}">{{risposta.testoRisposta}}</label><br>
                    {% endfor %}
                    <hr class="me-5">
                </div>
                {% endfor %}
            </ul>
        {% endfor %}
        <input type="submit" value="Conferma" class="btn btn-success bg-gradient m-2"/>
    </form>
{% endblock %}